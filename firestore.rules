rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── chapters ─────────────────────────────────────────────────────────────
    match /chapters/{chapterId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.userId;
    }

    // ── users + subcollections (notifications) ────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      match /notifications/{notifId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── leaderboard ──────────────────────────────────────────────────────────
    // Any authenticated user can read all entries.
    // A user can only write/update their own entry (doc ID == their UID).
    match /leaderboard/{weekId}/entries/{entryUid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == entryUid;
    }

    // ── classes ───────────────────────────────────────────────────────────────
    // Any authenticated user can create a class or read classes (needed for invite-code lookup).
    // Only the owner (createdBy) can update or delete.
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.createdBy;

      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }

      match /shared/{sharedId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && request.auth.uid == resource.data.sharedBy;
      }
    }

    // ── discussions ───────────────────────────────────────────────────────────
    // Any authenticated user can read and create posts/replies.
    // Only the post author (uid field) can delete their own post.
    // Any authenticated user can upvote (update).
    match /discussions/{chapterId}/posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;

      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && request.auth.uid == resource.data.uid;
      }
    }

    // ── chatSessions ──────────────────────────────────────────────────────────
    // Users can only read/write their own chat sessions (userId field == uid).
    match /chatSessions/{sessionId} {
      allow read, update, delete: if request.auth != null
                                  && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }

    // ── feedback ──────────────────────────────────────────────────────────────
    // Authenticated users can submit feedback (create only).
    // Users can read their own feedback reports.
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
    }

    // ── shares ────────────────────────────────────────────────────────────────
    // Public share links — anyone (including unauthenticated) can read.
    // Only the authenticated owner can create, update, or delete their share.
    match /shares/{token} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }
  }
}
