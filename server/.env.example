# ─── Required ─────────────────────────────────────────────────────────────────

# NVIDIA NIM API key — get from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins (your Vercel URL)
# Example: https://topper-2.vercel.app
# Leave as * during development to allow all origins
ALLOWED_ORIGIN=*

# ─── Optional ─────────────────────────────────────────────────────────────────

# Port (Render sets this automatically — do not change in production)
PORT=3001

# Environment
NODE_ENV=production
